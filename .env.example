# ─────────────────────────────────────────────────────────────────────────────
# BetterSite — environment configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values. Never commit .env.
# Every value below must be populated before the pipeline runs end-to-end
# (unless marked OPTIONAL).
#
# See README.md "Tech Stack" and "Critical Implementation Constraints"
# for context on what each service is used for.
# ─────────────────────────────────────────────────────────────────────────────


# ── Application ──────────────────────────────────────────────────────────────

# Current environment: "staging" | "production" | "local"
APP_ENV=staging

# Public-facing base URL used when generating preview links in emails.
# Staging: https://bettersite-staging.up.railway.app
# Production: https://bettersite.co
APP_BASE_URL=https://bettersite-staging.up.railway.app

# Secret used to sign internal artifacts (share-with-partner tokens, etc.)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_SECRET_KEY=


# ── Database (Railway Postgres) ──────────────────────────────────────────────

# Full Postgres DSN. Railway provides this automatically as DATABASE_URL
# when you attach a Postgres service. Example:
#   postgresql+psycopg://user:pass@host:5432/bettersite
DATABASE_URL=


# ── Prefect (Railway template) ───────────────────────────────────────────────

# Railway's Prefect template exposes an API URL you paste here.
# Format: https://<prefect-service>.up.railway.app/api
PREFECT_API_URL=

# API key created inside Prefect UI → Settings → API Keys.
PREFECT_API_KEY=


# ── Cloudflare R2 (object storage for assets) ────────────────────────────────

# Cloudflare account ID (dashboard → R2).
R2_ACCOUNT_ID=

# R2 API token with Object Read + Write permission on the bucket below.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Bucket name (create in R2 dashboard first).
R2_BUCKET_NAME=bettersite-assets

# S3-compatible endpoint. Format:
#   https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=

# Public base URL for assets (after enabling R2 public bucket or custom domain).
# Used when embedding images in emails and previews.
R2_PUBLIC_BASE_URL=


# ── Anthropic Claude (Extractor vision + Builder copy polish) ────────────────

# API key from console.anthropic.com
ANTHROPIC_API_KEY=

# Model ID. Default is Claude Sonnet 4.6 with 1M context.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Per-batch cost ceiling in USD. Halts the batch and alerts if exceeded.
# See Critical Constraints in README. Starting value: $20 per 200-lead batch.
CLAUDE_COST_CEILING_PER_BATCH_USD=20.0


# ── Google Maps Places API (lead generation + GMB data) ──────────────────────

# From https://console.cloud.google.com/ — enable Places API (New).
GOOGLE_MAPS_API_KEY=


# ── Hunter.io (email finder) ─────────────────────────────────────────────────

HUNTER_API_KEY=


# ── ZeroBounce (email verification hard gate) ────────────────────────────────

ZEROBOUNCE_API_KEY=


# ── Google PageSpeed Insights (website scanner scoring) ──────────────────────

# Optional but recommended — raises the quota from 25/min to 25k/day.
# Create at https://console.cloud.google.com/ — enable PageSpeed Insights API.
PAGESPEED_API_KEY=


# ── Stripe (payments + Checkout) ─────────────────────────────────────────────

# Publishable key (exposed to Next.js). Starts with pk_test_ or pk_live_.
STRIPE_PUBLISHABLE_KEY=

# Secret key (server-side only, never in Next.js).
STRIPE_SECRET_KEY=

# Webhook signing secret (from Stripe Dashboard → Developers → Webhooks).
# Used to verify /webhooks/stripe signatures.
STRIPE_WEBHOOK_SECRET=

# Stripe Price ID for the $399 one-time purchase. Create in Stripe Dashboard:
# Products → BetterSite Website → $399 one-time.
STRIPE_PRICE_ID=


# ── Sentry (error monitoring) ────────────────────────────────────────────────

# Python DSN (pipeline + api)
SENTRY_DSN=

# Next.js DSN (exposed to client)
NEXT_PUBLIC_SENTRY_DSN=


# ── Admin dashboard basic auth ───────────────────────────────────────────────

# Rotate on a calendar reminder. Never commit real credentials.
ADMIN_BASIC_AUTH_USER=
ADMIN_BASIC_AUTH_PASSWORD=


# ── Extractor strategy selector ──────────────────────────────────────────────

# Which ExtractionStrategy to run in the pipeline.
# Options: html_only | vision_full | hybrid | gmb_first
# All four are implemented; the winner is picked manually during Phase 3
# by comparing outputs on real URLs.
EXTRACTION_STRATEGY=html_only


# ── Sales agent backend ──────────────────────────────────────────────────────

# Which SalesAgentBackend to use. In v0 only null/console exist. Real backend
# (e.g. smartlead, instantly, smtp, postmark) is added in Phase 5 pre-flight.
# Options: null | console | smartlead | instantly | smtp | postmark
SALES_AGENT_BACKEND=null

# Populated later based on the chosen backend:
# SMARTLEAD_API_KEY=
# INSTANTLY_API_KEY=
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# POSTMARK_SERVER_TOKEN=


# ── Feature flags / tuning knobs ─────────────────────────────────────────────

# Scanner pass/fail threshold (0-100). Leads scoring above this are rejected.
# Tunable during Phase 2 based on actual lead quality distribution.
SCANNER_PASS_THRESHOLD=60

# Preview expiry in hours. CEO plan locked at 48.
PREVIEW_EXPIRY_HOURS=48

# Follow-up email delay in hours.
FOLLOWUP_DELAY_HOURS=24


# ── OPTIONAL — Next.js public env ────────────────────────────────────────────

# Anything prefixed with NEXT_PUBLIC_ is visible in the browser bundle.
# Never put secrets here. Keep in sync with the server-side values above.
NEXT_PUBLIC_APP_BASE_URL=https://bettersite-staging.up.railway.app
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
